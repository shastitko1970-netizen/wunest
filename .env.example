# ── HTTP ──────────────────────────────────────────
HTTP_PORT=9090
PUBLIC_BASE_URL=https://nest.wusphere.ru

# ── Database (own DB on shared Postgres instance) ─
# In docker-compose, hostname is "postgres"; locally use "localhost"
DATABASE_URL=postgresql://wunest:changeme@postgres:5432/wunest
PG_PASSWORD=changeme
PG_PORT=5434

# ── Redis (shared with WuApi, dedicated namespace) ─
REDIS_URL=redis://redis:6379/1
REDIS_NAMESPACE=nest

# ── WuApi upstream ────────────────────────────────
# Public API — used for LLM proxying and /api/me lookups.
WUAPI_BASE_URL=https://api.wusphere.ru

# Optional internal URL (e.g. http://127.0.0.1:8080) to skip nginx/TLS on the
# same host. CAREFUL: WuApi uses blue/green deploys that swap between 8080
# and 8081. If you pin this to a specific color it will go stale on the
# next swap. The client auto-fails over to BaseURL on connection-refused,
# but it's simpler to leave this empty in prod and eat one extra loopback
# TLS hop.
WUAPI_INTERNAL_URL=

# ── Session / security ────────────────────────────
# Cookie domain WuApi uses. WuNest must read the same domain.
SESSION_COOKIE_DOMAIN=.wusphere.ru
SESSION_COOKIE_NAME=wu_session

# AES-GCM key for encrypting BYOK (bring-your-own-key) secrets.
# Generate with: openssl rand -base64 32
SECRETS_KEY=change-me-to-a-random-32-byte-base64-value

# CSRF secret for same-origin POST protection.
# Generate with: openssl rand -base64 32
CSRF_SECRET=change-me-to-a-random-32-byte-base64-value

# ── Object storage (MinIO) ────────────────────────
# Image uploads (character avatars, message attachments, user backgrounds).
# Leave MINIO_ENDPOINT empty to disable — avatars simply won't be stored.
#
# Endpoint is the host:port Go dials directly. Use loopback on servers
# where MinIO runs on the same host, or "minio:9000" inside docker-compose.
MINIO_ENDPOINT=127.0.0.1:9000
MINIO_ACCESS_KEY=nestadmin
MINIO_SECRET_KEY=change-me-to-match-minio-root-password
MINIO_USE_SSL=false
# PublicBaseURL is the origin where the nginx `/images/*` proxy is served.
# Defaults to PUBLIC_BASE_URL when empty — override only when images are
# hosted on a separate subdomain (media.wusphere.ru etc.).
MINIO_PUBLIC_BASE_URL=

# ── Runtime ───────────────────────────────────────
# production | staging | development
ENV=development
LOG_LEVEL=debug
